# =============================================================================
# BatMotor front (MongoDB stack) — Vite
# Copia para .env ou define no Render (Build Environment) antes do npm run build
# =============================================================================

# --- URL da API (backend_mongoDB) ---
# Desenvolvimento local (padrão ao copiar este ficheiro):
VITE_API_URL=http://localhost:3000
#
# Produção Render (API atual): https://batmotor-api-w3ad.onrender.com
# Troca a linha acima para essa URL se quiseres testar contra produção localmente.
#
# Netlify: Site settings → Environment variables (Build) — obrigatório antes do deploy:
#   VITE_API_URL = https://batmotor-api-w3ad.onrender.com
#   VITE_USE_MOCK = false
# Base directory do site: frontend - mongoDB (ver netlify.toml)

# false = chamadas reais ao backend; true = dados mock (sem rede)
VITE_USE_MOCK=false

# Opcional: cadastro gestor (se o backend usar o mesmo token)
# VITE_MANAGER_REGISTRATION_TOKEN=batmotor-gestor-dev
