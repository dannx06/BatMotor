# Copie para .env e ajuste se necessário.
# MySQL do Docker em localhost:MYSQL_PORT_HOST (evita conflito com MySQL local na porta MYSQL_PORT_HOST).

# A API usa primeiro `DATABASE_URL` para o adapter (recomendado em produção). Se não houver URL válida,
# usa DATABASE_HOST + DATABASE_USER + DATABASE_PASSWORD + DATABASE_NAME (+ DATABASE_PORT).
DATABASE_URL="mysql://MYSQL_USER:MYSQL_PASSWORD@MYSQL_HOST:MYSQL_PORT_HOST/MYSQL_DATABASE"
SHADOW_DATABASE_URL="mysql://ROOT_USER:ROOT_PASSWORD@MYSQL_HOST:MYSQL_PORT_HOST/MYSQL_DATABASE"

# Se o pool der timeout com MySQL 8, confirme allowPublicKeyRetrieval no prisma.ts (ou use mysql_native_password no servidor).
DATABASE_HOST=MYSQL_HOST
DATABASE_USER=MYSQL_USER
DATABASE_PASSWORD=MYSQL_PASSWORD
DATABASE_NAME=MYSQL_DATABASE
DATABASE_PORT=MYSQL_PORT_HOST

# Autenticação:
# - Login: e-mail institucional, senha, role/perfil_id. ADMIN/GERENTE também enviam chaveAcesso.
# - Banco sem usuários: POST /auth/primeiro-admin com chaveAcesso + dados do admin.
# - Cadastro interno: POST /auth/register ou POST /users com Authorization: Bearer <JWT> (ADMIN/GERENTE).
ACCESS_KEY=troque_esta_chave
# ACCESS_KEY_ADMIN=
JWT_SECRET=troque_por_string_longa_e_aleatoria

# Saídas de estoque com quantidade >= este valor exigem perfil ADMIN ou GERENTE (padrão: 500).
# LARGE_OUT_THRESHOLD=500

# Origens permitidas para o navegador (CORS). Padrão: Vite local. Vários valores separados por vírgula.
# CORS_ORIGINS=http://localhost:5173,https://app.suaempresa.com

# Alertas por e-mail (equipe de compras) — POST /relatorios/estoque-baixo/enviar-email (ADMIN/GERENTE)
# SMTP_HOST=smtp.seuprovedor.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Batmotor <alertas@empresa.com>"
# ALERT_EMAIL_TO=compras@empresa.com,logistica@empresa.com
