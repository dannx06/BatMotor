{
	"info": {
		"_postman_id": "a1b2c3d4-batmotor-api",
		"name": "BatMotor API",
		"description": "Coleção de desenvolvimento. 1) Rode o login — o script grava `token` na coleção. 2) Demais requests usam Bearer. Credenciais padrão após seed: ver variável `loginEmail` / `loginSenha` ou `prisma/seed.ts`. Ajuste IDs nas variáveis após criar registros (fornecedor_id, materia_prima_id, etc.).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:3000" },
		{ "key": "token", "value": "" },
		{ "key": "loginEmail", "value": "admin@batmotor.com" },
		{ "key": "loginSenha", "value": "adminbatmotor" },
		{ "key": "fornecedor_id", "value": "1" },
		{ "key": "materia_prima_id", "value": "1" },
		{ "key": "usuario_id", "value": "1" },
		{ "key": "perfil_id", "value": "1" },
		{ "key": "modulo_id", "value": "1" },
		{ "key": "movimentacao_id", "value": "1" }
	],
	"item": [
		{
			"name": "01 — Autenticação",
			"item": [
				{
					"name": "POST Login (salva token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const j = pm.response.json();",
									"    if (j.token) {",
									"        pm.collectionVariables.set('token', j.token);",
									"        console.log('Token gravado em {{token}}');",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"{{loginEmail}}\",\n  \"senha\": \"{{loginSenha}}\"\n}"
						},
						"url": "{{baseUrl}}/auth/login",
						"description": "Body em JSON válido: strings entre aspas duplas, sem vírgula antes do `}` final. Troque loginEmail/loginSenha nas variáveis da coleção."
					},
					"response": []
				}
			]
		},
		{
			"name": "02 — Almoxarifado",
			"auth": {
				"type": "bearer",
				"bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
			},
			"item": [
				{
					"name": "POST Fornecedor",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nome\": \"Fornecedor Exemplo LTDA\",\n  \"cnpj\": \"11222333000181\",\n  \"email\": \"contato@fornecedor.com\",\n  \"telefone\": \"11999990000\"\n}"
						},
						"url": "{{baseUrl}}/fornecedores"
					},
					"response": []
				},
				{
					"name": "GET Fornecedores",
					"request": { "method": "GET", "url": "{{baseUrl}}/fornecedores" },
					"response": []
				},
				{
					"name": "GET Fornecedor por id",
					"request": { "method": "GET", "url": "{{baseUrl}}/fornecedores/{{fornecedor_id}}" },
					"response": []
				},
				{
					"name": "POST Matéria-prima",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nome\": \"Parafuso 10mm\",\n  \"categoria\": \"Fixação\",\n  \"unidade\": \"UN\",\n  \"estoque_minimo\": 100,\n  \"ativo\": true\n}"
						},
						"url": "{{baseUrl}}/materia-prima"
					},
					"response": []
				},
				{
					"name": "GET Matérias-prima",
					"request": { "method": "GET", "url": "{{baseUrl}}/materia-prima" },
					"response": []
				},
				{
					"name": "POST Matéria-fornecedor (vínculo)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"materia_prima_id\": {{materia_prima_id}},\n  \"fornecedor_id\": {{fornecedor_id}}\n}"
						},
						"url": "{{baseUrl}}/materia-fornecedor"
					},
					"response": []
				},
				{
					"name": "POST Movimentação (ENTRADA)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"materia_prima_id\": {{materia_prima_id}},\n  \"tipo\": \"ENTRADA\",\n  \"quantidade\": 50,\n  \"motivo\": \"Compra inicial\"\n}"
						},
						"url": "{{baseUrl}}/movimentacao"
					},
					"response": []
				},
				{
					"name": "GET Movimentações",
					"request": { "method": "GET", "url": "{{baseUrl}}/movimentacao" },
					"response": []
				},
				{
					"name": "GET Estoque atual",
					"request": { "method": "GET", "url": "{{baseUrl}}/estoque-atual" },
					"response": []
				}
			]
		},
		{
			"name": "03 — Usuários (ADMIN)",
			"auth": {
				"type": "bearer",
				"bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
			},
			"item": [
				{
					"name": "GET Usuários",
					"request": { "method": "GET", "url": "{{baseUrl}}/users" },
					"response": []
				},
				{
					"name": "POST Usuário",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nome\": \"Funcionário Teste\",\n  \"email\": \"funcionario@exemplo.com\",\n  \"senha\": \"senhaForte123\",\n  \"cpf\": \"52998224725\",\n  \"ativo\": true\n}"
						},
						"url": "{{baseUrl}}/users"
					},
					"response": []
				}
			]
		},
		{
			"name": "04 — Config (ADMIN)",
			"auth": {
				"type": "bearer",
				"bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
			},
			"item": [
				{
					"name": "POST Perfil",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"role\": \"GERENTE\",\n  \"descricao\": \"Gerência (exemplo Postman)\"\n}"
						},
						"url": "{{baseUrl}}/perfil"
					},
					"response": []
				},
				{
					"name": "GET Perfis",
					"request": { "method": "GET", "url": "{{baseUrl}}/perfil" },
					"response": []
				},
				{
					"name": "POST Módulo",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nome\": \"Almoxarifado\",\n  \"descricao\": \"Gestão de estoque\"\n}"
						},
						"url": "{{baseUrl}}/modulos"
					},
					"response": []
				},
				{
					"name": "POST User-perfil (vincular)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"usuario_id\": {{usuario_id}},\n  \"perfil_id\": {{perfil_id}}\n}"
						},
						"url": "{{baseUrl}}/user-perfil"
					},
					"response": []
				},
				{
					"name": "POST Permissão módulo",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"perfil_id\": {{perfil_id}},\n  \"modulo_id\": {{modulo_id}},\n  \"pode_ler\": true,\n  \"pode_criar\": true,\n  \"pode_atualizar\": false,\n  \"pode_excluir\": false\n}"
						},
						"url": "{{baseUrl}}/permissao-modulo"
					},
					"response": []
				}
			]
		},
		{
			"name": "05 — Teste (ADMIN)",
			"auth": {
				"type": "bearer",
				"bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
			},
			"item": [
				{
					"name": "POST Teste",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nome\": \"Registro Teste\",\n  \"email\": \"teste@exemplo.com\",\n  \"senha\": \"qualquer\"\n}"
						},
						"url": "{{baseUrl}}/teste"
					},
					"response": []
				},
				{
					"name": "GET Teste",
					"request": { "method": "GET", "url": "{{baseUrl}}/teste" },
					"response": []
				}
			]
		}
	]
}
