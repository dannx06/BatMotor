# MongoDB (obrigatório para este backend)
MONGODB_URI=mongodb://127.0.0.1:27017/batmotor

# API
PORT=3000

# JWT
JWT_SECRET=troque_por_string_longa_e_aleatoria
JWT_EXPIRES_IN=8h

# Saídas de estoque >= valor exigem ADMIN ou GERENTE (padrão 500)
# LARGE_OUT_THRESHOLD=500

# CORS: origens extra (vírgula). Locais (5173/4173) já vêm por defeito.
#
# Front na Netlify (exacto — recomendado):
#   CORS_ORIGINS=https://golden-halva-731318.netlify.app
# Ou vários sites:
#   CORS_ORIGINS=https://meu-site.netlify.app,https://preview--meu-site.netlify.app
#
# Alternativa: permite qualquer subdomínio HTTPS *.netlify.app (útil em deploys de teste):
#   CORS_ALLOW_NETLIFY=true

# E-mail alertas (opcional)
# SMTP_HOST=
# SMTP_PORT=587
# ALERT_EMAIL_TO=
