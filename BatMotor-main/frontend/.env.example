# --- URL da API (obrigatório com VITE_USE_MOCK=false) ---
# Desenvolvimento (backend na mesma máquina):
VITE_API_URL=http://localhost:3000
#
# Produção: URL HTTPS da API após deploy (AWS, Render, etc.), sem barra no fim.
# Defina em `.env.production` ou no painel do serviço de hospedagem do front antes do `npm run build`.
#
# O Vite incorpora VITE_API_URL no *build*; alterar depois exige novo build (ou variável no CI).

# false = axios usa VITE_API_URL; true = dados mock locais (padrão se omitido: true)
# Preferência local em localStorage (batmotor-api-mode) só se algo chamar setApiMode no código.
VITE_USE_MOCK=false

# Opcional: mesmo valor do MANAGER_REGISTRATION_TOKEN no backend (cadastro gestor)
# VITE_MANAGER_REGISTRATION_TOKEN=batmotor-gestor-dev
